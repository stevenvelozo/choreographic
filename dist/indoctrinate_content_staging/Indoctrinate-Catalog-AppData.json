            "UUID": "41d27676-768a-4bf6-84c1-04449775b134",
            "Type": "URI",
            "Hash": "URI~CONTENT~FILE://Users/steven/Code/retold/modules/utility/choreographic/package.json",
            "Path": "FILE://Users/steven/Code/retold/modules/utility/choreographic/package.json",
